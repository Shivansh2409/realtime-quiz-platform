# Backend Environment Variables Example
# Copy this to .env and fill in your values

# Server Configuration
PORT=3001

# MongoDB Connection (use mongodb://localhost:27017/quiz-platform for local)
# Or use MongoDB Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/quiz-platform
MONGODB_URI=mongodb://localhost:27017/quiz-platform

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Node Environment
NODE_ENV=development

